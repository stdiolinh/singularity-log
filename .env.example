# Copy to .env and fill in one provider.

# --- OpenAI (default if AI_PROVIDER unset or openai) ---
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
# OPENAI_MAX_TOKENS=900
# OPENAI_TEMPERATURE=0.78

# --- Anthropic (set AI_PROVIDER=anthropic) ---
# AI_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
# ANTHROPIC_MAX_TOKENS=1024

# Server
# PORT=8765

# --- GitHub Pages static build (npm run build:pages) ---
# Set PAGES_API_BASE to your deployed Node API URL (no trailing slash), then rebuild docs/.
# Example: PAGES_API_BASE=https://singularity-log-api.onrender.com npm run build:pages
# GitHub Actions: add repo secret PAGES_API_BASE with the same URL so the workflow injects it.
